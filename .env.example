# Required: OpenAI API key for agent LLM calls
OPENAI_API_KEY=sk-your-key-here

# Optional: OpenAI model (defaults to gpt-4.1 in agents/base.py)
# OPENAI_MODEL=gpt-4.1

# Optional: Server host/port (defaults to 0.0.0.0:8000)
# HOST=0.0.0.0
# PORT=8000

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
